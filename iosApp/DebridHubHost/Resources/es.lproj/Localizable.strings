"trust_center.about_line_3" = "DebridHub usa los endpoints oficiales de la API de Real-Debrid y el flujo de autenticación por dispositivo documentado. Los usuarios siguen siendo responsables de cumplir los Términos y las reglas de cuenta de Real-Debrid.";
"trust_center.about_title" = "Acerca de y cumplimiento";
"trust_center.diagnostics_line_1" = "La exportación de diagnósticos incluye actualmente la versión de la app, la versión del sistema operativo, la última sincronización, el estado de vencimiento de la cuenta y algunas marcas de ejecución no sensibles.";
"trust_center.diagnostics_line_2" = "La exportación de diagnósticos excluye tokens de acceso, tokens de actualización, secretos de cliente, nombre de usuario, correo electrónico e historial completo de la cuenta.";
"trust_center.diagnostics_title" = "Diagnósticos";
