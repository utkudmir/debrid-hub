"trust_center.privacy_line_1" = "DebridHub no tiene backend. La app se comunica directamente con Real-Debrid desde tu dispositivo.";
"trust_center.privacy_line_2" = "No hay SDK de analítica, píxel de seguimiento, servicio de informes de fallos ni sincronización remota de la cuenta en la app actual.";
